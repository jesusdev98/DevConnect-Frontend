{
  "name": "devconnect-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:staging": "ng serve --configuration staging",
    "dev": "ng serve",
    "dev:ci": "ng serve --host 127.0.0.1 --port 4200",
    "build": "node scripts/build.mjs",
    "build:staging": "ng build --configuration staging",
    "build:angular": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "e2e": "wait-on http://127.0.0.1:4200 && cypress run",
    "e2e:local": "wait-on http://127.0.0.1:4200 http://127.0.0.1:8001 && cypress run"
  },
  "private": true,
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "dependencies": {
    "@angular/common": "^21.2.15",
    "@angular/compiler": "^21.2.15",
    "@angular/core": "^21.2.15",
    "@angular/forms": "^21.2.15",
    "@angular/platform-browser": "^21.2.15",
    "@angular/platform-browser-dynamic": "^21.2.15",
    "@angular/router": "^21.2.15",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.15",
    "axe-core": "^4.11.4",
    "cypress": "15.16.0",
    "cypress-axe": "^1.7.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.10"
  }
}
